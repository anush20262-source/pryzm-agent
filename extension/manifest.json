{
  "manifest_version": 3,
  "name": "PRYZM — AI Competitive Intelligence",
  "version": "3.0.0",
  "description": "AI-powered competitive intelligence for e-commerce. 3 AI agents research competitors, analyze gaps, generate ad creatives, and chat with you about your business — all inside your browser.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.myshopify.com/*",
    "https://*.shopify.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Open PRYZM",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.myshopify.com/*",
        "https://*.shopify.com/*",
        "https://*.woocommerce.com/*",
        "https://*.bigcommerce.com/*",
        "https://*.squarespace.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
