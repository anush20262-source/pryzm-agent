{
  "manifest_version": 3,
  "name": "PRYZM — Competitive Intelligence Agent",
  "version": "1.0.0",
  "description": "AI-powered competitive intelligence for e-commerce stores. Reveals market gaps, competitor strategies, and generates ready-to-deploy marketing creatives.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.myshopify.com/*",
    "https://*.shopify.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
